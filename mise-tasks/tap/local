#!/usr/bin/env zsh
#MISE description="Tap this repo from the local working directory"
set -euo pipefail

remote_url=$(git remote get-url origin)
org_repo=${remote_url#*github.com[:/]}
org_repo=${org_repo%.git}
org=${org_repo%%/*}
repo=${org_repo#*/}
tap_name="${org}/${repo#homebrew-}"
local_path=$(git rev-parse --show-toplevel)

if tap_info=$(brew tap-info --json "$tap_name" 2>/dev/null); then
  current_remote=$(jq -r '.[0].remote' <<<"$tap_info")
  if [[ "$current_remote" == "$local_path" ]]; then
    echo "$tap_name is already tapped from $local_path"
    exit 0
  fi
  echo "Untapping $tap_name (currently from $current_remote)..."
  brew untap "$tap_name"
fi

echo "Tapping $tap_name from local directory..."
brew tap "$tap_name" "$local_path"
tap_info=$(brew tap-info --json "$tap_name")
jq -r '.[0] | [
  "Tapped: \(.name // "n/a")",
  "Remote: \(.remote // "n/a")",
  "Path: \(.path // "n/a")"
] | join("\n")' <<<"$tap_info"
